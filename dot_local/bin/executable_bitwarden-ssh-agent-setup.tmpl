#!/bin/sh

BITWARDEN_SOCK="$HOME/.bitwarden-ssh-agent.sock"
BITWARDEN_STORE_SOCK="$HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock"
ONEPASSWORD_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

TARGET_SOCK="$BITWARDEN_SOCK"
if [ -S "$BITWARDEN_STORE_SOCK" ]; then
  TARGET_SOCK="$BITWARDEN_STORE_SOCK"
elif [ ! -S "$TARGET_SOCK" ] && [ -S "$ONEPASSWORD_SOCK" ]; then
  TARGET_SOCK="$ONEPASSWORD_SOCK"
fi

/bin/ln -sf "$TARGET_SOCK" "$SSH_AUTH_SOCK"
